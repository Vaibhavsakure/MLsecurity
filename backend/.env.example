# Backend Configuration — SocialGuard AI
# Copy this file to .env and fill in your credentials.
# NEVER commit your actual .env file.

# ---------------------------------------------------------------------------
# CORS — comma-separated list of allowed origins
# For local dev: http://localhost:5173,http://127.0.0.1:5173
# For production: https://your-app.vercel.app
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# Rate limiting (format: "N/period")
# Periods: second | minute | hour
# ---------------------------------------------------------------------------
RATE_LIMIT=60/minute

# ---------------------------------------------------------------------------
# Firebase Admin SDK
# Download from Firebase Console → Project Settings → Service Accounts
# Place the JSON file in backend/ and update the path below.
# If not set, auth middleware runs in dev-bypass mode (all requests allowed).
# ---------------------------------------------------------------------------
FIREBASE_CREDENTIALS_PATH=./firebase-adminsdk.json

# ---------------------------------------------------------------------------
# AI Chatbot — Groq (primary, fast, free tier)
# Get your key at: https://console.groq.com
# ---------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# ---------------------------------------------------------------------------
# AI Chatbot — Gemini (fallback if Groq is unavailable)
# Get your key at: https://aistudio.google.com/app/apikey
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
